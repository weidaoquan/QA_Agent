# LLM Provider: "deepseek" | "openai" | "anthropic"
LLM_PROVIDER=deepseek

# DeepSeek Configuration (default)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI Configuration (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Embedding Provider: "local" | "openai"
EMBEDDING_PROVIDER=local
# Model name (HuggingFace model ID for local, OpenAI model name for openai)
EMBEDDING_MODEL=BAAI/bge-m3

# Local Model Directory (for local embeddings)
LOCAL_MODEL_DIR=models

# Paths (relative to project root)
DOCS_DIR=docs
CHROMA_PERSIST_DIR=chroma_db

# Chunking Parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Retrieval
RETRIEVAL_K=4

# Memory
MEMORY_FILE=conversation_history.json
